# Copy this file to ".env" and fill in your key. All values are optional.

# Free Gemini key (no credit card): https://aistudio.google.com/apikey
# Leave blank to run with the honest template fallback (no LLM).
GEMINI_API_KEY=

# gemini-2.5-flash-lite = most generous free quota + lightest (default)
# gemini-2.5-flash      = higher-quality copy, smaller free quota
GEMINI_MODEL=gemini-2.5-flash-lite

# Pipeline behaviour
REFRESH_HOURS=2          # how often to re-sync news (>=1 recommended)
TOP_N=5                  # how many top stories to surface
NEWS_SCOPE=niche         # "niche" (recommended) or "general"
